{
  "name": "porch",
  "version": "0.0.0",
  "private": true,
  "description": "Porch — a five-mode social platform with persona-native identity.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @porch/db generate",
    "db:migrate": "pnpm --filter @porch/db migrate",
    "db:studio": "pnpm --filter @porch/db studio",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "turbo": "^2.0.3",
    "typescript": "^5.4.5"
  }
}
