{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "noEmit": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@porch/core": ["../../packages/core/src/index.ts"],
      "@porch/core/*": ["../../packages/core/src/*"],
      "@porch/db": ["../../packages/db/src/index.ts"],
      "@porch/db/*": ["../../packages/db/src/*"],
      "@porch/types": ["../../packages/types/src/index.ts"],
      "@porch/types/*": ["../../packages/types/src/*"],
      "@porch/ui": ["../../packages/ui/src/index.ts"],
      "@porch/ui/*": ["../../packages/ui/src/*"],
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next"]
}
