# Porch environment config — copy to .env.local for dev, or populate via
# `wrangler secret put` / your deploy host's secret manager in prod.
# See DEPLOYMENT.md for the prod setup walkthrough.

# ── Required (API + web) ────────────────────────────────────────────────────

# Database (Neon serverless Postgres pooled connection string)
# Prod: use the *pooled* endpoint, not the direct one — Neon's pooler handles
# Workers' short-lived request model.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Encryption key for persona private keys at rest (AES-256-GCM).
# 32 bytes, base64-encoded. Generate with:
#   openssl rand -base64 32
# Never rotate without a re-encryption migration — rotating orphans every
# existing persona's signing key.
PERSONA_KEY_ENCRYPTION_KEY=""

# JWT signing key for access tokens (HS256 in v0).
# 32+ bytes, base64-encoded. Generate with:
#   openssl rand -base64 48
# Rotating invalidates every live access token — users are bumped to re-auth
# on the next refresh. Safe to rotate at will; no re-encryption needed.
JWT_SIGNING_KEY=""

# Public host used in did:web identifiers and DID document URLs.
# Local dev: localhost%3A3000   (URL-encoded host:port per did:web)
# Prod:      porch.example      (the web app's host — the `.well-known` path
#                                 lives there, not on the API worker)
PORCH_HOST="localhost%3A3000"

# Origin used by the API for CORS / refresh-cookie scope.
WEB_ORIGIN="http://localhost:3000"

# API base URL the web app should call (client-exposed).
NEXT_PUBLIC_API_URL="http://localhost:8787"

# ── Optional ────────────────────────────────────────────────────────────────

# Moderator allowlist — comma-separated account UUIDs permitted to hit
# POST /api/moderation/posts/:id/action and /personas/:id/action. Unset or
# empty means no admins; every moderation write endpoint 403s.
# Whitespace around commas is tolerated.
# PORCH_ADMIN_ACCOUNT_IDS="00000000-0000-0000-0000-000000000001,00000000-0000-0000-0000-000000000002"

# Runtime selector for the API. Set to 'node' when running via server.node.ts
# so dbMiddleware picks the postgres-js TCP driver (transactions). Workers
# deploys leave this unset and use the HTTP driver.
# PORCH_RUNTIME=""

# ── Deferred until v0.5 — not read by any code in v0 ───────────────────────

# Email provider (Postmark in the planned wiring — see DEPLOYMENT.md §Postmark).
# EMAIL_PROVIDER="postmark"
# EMAIL_FROM="no-reply@porch.example"
# POSTMARK_SERVER_TOKEN=""

# Cloudflare R2 — storage for avatar + post media. Ships with the upload
# flow in v0.5 (spec §18.1).
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET=""
