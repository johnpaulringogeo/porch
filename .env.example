# Database (Neon serverless Postgres connection string)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Encryption key for persona private keys at rest.
# 32 bytes, base64-encoded. Generate with: openssl rand -base64 32
PERSONA_KEY_ENCRYPTION_KEY=""

# JWT signing key for access tokens (HS256 in v0).
# 32+ bytes, base64-encoded. Generate with: openssl rand -base64 48
JWT_SIGNING_KEY=""

# Public host used in did:web identifiers and DID document URLs.
# Local dev: localhost%3A3000  (URL-encoded host:port)
# Prod:      porch.example
PORCH_HOST="localhost%3A3000"

# Origin used by the API for CORS / cookie domain.
WEB_ORIGIN="http://localhost:3000"

# API base URL the web app should call.
NEXT_PUBLIC_API_URL="http://localhost:8787"

# Email provider (deferred — picked in Phase 1)
EMAIL_PROVIDER=""
EMAIL_FROM=""

# Cloudflare R2 (deferred — no media in v0)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
